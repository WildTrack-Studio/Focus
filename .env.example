# ==============================================
# FOCUS - Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your values

# ==============================================
# APPLICATION
# ==============================================
NODE_ENV=development
APP_NAME=FOCUS
APP_URL=http://localhost:3000

# ==============================================
# FRONTEND (Next.js)
# ==============================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ML_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# ==============================================
# BACKEND (NestJS)
# ==============================================
PORT=4000
API_PREFIX=api/v1

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRATION=30d

# ==============================================
# DATABASE (PostgreSQL)
# ==============================================
DATABASE_URL=postgresql://focus_user:focus_password@localhost:5432/focus_db?schema=public
POSTGRES_USER=focus_user
POSTGRES_PASSWORD=focus_password
POSTGRES_DB=focus_db
POSTGRES_PORT=5432

# ==============================================
# ML SERVICE (FastAPI)
# ==============================================
ML_SERVICE_PORT=8000
ML_SERVICE_HOST=0.0.0.0

# Model Configuration
YOLO_MODEL_PATH=./weights/yolov8n.pt
CLASSIFICATION_MODEL_PATH=./weights/classifier.pth
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# ==============================================
# STORAGE (S3 Compatible - MinIO)
# ==============================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=focus-images
S3_REGION=us-east-1
S3_USE_SSL=false

# ==============================================
# REDIS (Queue & Cache)
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==============================================
# EMAIL (Optional - for notifications)
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@focus-wildlife.com

# ==============================================
# MONITORING (Optional)
# ==============================================
SENTRY_DSN=
LOG_LEVEL=debug

# ==============================================
# RATE LIMITING
# ==============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ==============================================
# FILE UPLOAD
# ==============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg
MAX_FILES_PER_UPLOAD=100

# ==============================================
# SECURITY
# ==============================================
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000
COOKIE_SECRET=your-cookie-secret-change-this

# ==============================================
# DEVELOPMENT TOOLS
# ==============================================
DEBUG=false
ENABLE_SWAGGER=true
ENABLE_PLAYGROUND=true
